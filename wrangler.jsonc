{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "climbex-site",
  "compatibility_date": "2026-05-27",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "directory": "./dist/client",
    "binding": "ASSETS"
  },
  "main": "./dist/server/server.js",
  "observability": {
    "enabled": true
  }
}
